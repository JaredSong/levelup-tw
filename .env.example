# Copy to .env and fill in. Keep provider API keys server-side only.
# Provider can be chosen in-app (Stats → AI explanations); set the keys for
# whichever providers you want available. Restart dev server after editing.

# Gate token — invent any string, paste the same value into the app.
AI_ACCESS_TOKEN=choose-a-private-app-token

# Default provider if the app doesn't specify: anthropic | openai | gemini
AI_PROVIDER=anthropic

# Provider keys (fill the ones you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional model overrides
# (defaults: claude-3-5-haiku-latest / gpt-4o-mini / gemini-2.0-flash)
# ANTHROPIC_MODEL=
# OPENAI_MODEL=
# GEMINI_MODEL=
